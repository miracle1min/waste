# Google Sheets credentials (paste the entire JSON service account key as one line)
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Google Spreadsheet ID (from the URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# Cloudflare R2 Storage (replaces Cloudinary)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=ba-waste
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Google Drive Backup (optional)
# Folder ID from the URL: https://drive.google.com/drive/folders/{THIS_PART}
# Share folder with service account email from GOOGLE_SHEETS_CREDENTIALS
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
